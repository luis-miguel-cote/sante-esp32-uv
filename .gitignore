# ------------------------------------------------------------
# PlatformIO (ESP32 / ESP-IDF) - Common .gitignore
# ------------------------------------------------------------

# PlatformIO build system
.pio/
.pioenvs/
.piolibdeps/

# Some projects may produce a build/ dir too (esp-idf/cmake)
build/
cmake-build-*/

# CMake / Ninja caches (belt & suspenders)
CMakeCache.txt
CMakeFiles/
*.ninja
.ninja_*
compile_commands.json

# Toolchain/build outputs
*.o
*.obj
*.a
*.d
*.elf
*.bin
*.map
*.hex

# VS Code / IDE
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json

.idea/
*.code-workspace

# OS junk
.DS_Store
Thumbs.db

# Python caches (PlatformIO uses Python)
__pycache__/
*.py[cod]
.venv/
venv/

# Logs
*.log

# Secrets (avoid committing credentials)
.env
.env.*
secrets.*
*.pem
*.key
*.p12
*.pfx
include/secrets.h
dev.notes.md